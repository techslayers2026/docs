{
  "$schema": "https://mintlify.com/docs.json",
  "name": "TechSlayers Docs",
  "description": "API references and integration guides for TechSlayers products.",
  "theme": "mint",
  "colors": {
    "primary": "#176dd6",
    "light": "#208bff",
    "dark": "#176dd6"
  },
  "logo": {
    "light": "/assets/techslayers-logo.png",
    "dark": "/assets/techslayers-logo.png",
    "href": "https://www.techslayers.ca"
  },
  "favicon": "/assets/techslayers-icon.png",
  "background": {
    "decoration": "gradient",
    "color": {
      "dark": "#0A0F1F",
      "light": "#FFFFFF"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "search": {
    "prompt": "Search TechSlayers docs…"
  },
  "navbar": {
    "links": [
      { "label": "Home", "href": "https://www.techslayers.ca" },
      { "label": "Products", "href": "https://www.techslayers.ca/products" },
      { "label": "Services", "href": "https://www.techslayers.ca/services" }
    ],
    "primary": { "type": "button", "label": "Contact", "href": "https://www.techslayers.ca/#contact" }
  },
  "footer": {
    "socials": {
      "website": "https://www.techslayers.ca",
      "linkedin": "https://www.linkedin.com/company/techslayers/",
      "x": "https://twitter.com/techslayers"
    },
    "links": [
      {
        "header": "Products",
        "items": [
          { "label": "DarkRecon", "href": "https://www.techslayers.ca/products/dark-recon" },
          { "label": "Senthrex", "href": "https://www.techslayers.ca/products/senthrex" },
          { "label": "Red Team Suite", "href": "https://www.techslayers.ca/products/red-team-suite" },
          { "label": "Legba", "href": "https://www.techslayers.ca/products/legba" }
        ]
      },
      {
        "header": "Company",
        "items": [
          { "label": "About", "href": "https://www.techslayers.ca/about" },
          { "label": "Careers", "href": "https://www.techslayers.ca/careers" },
          { "label": "Blog", "href": "https://www.techslayers.ca/blog" }
        ]
      },
      {
        "header": "Support",
        "items": [
          { "label": "Email", "href": "mailto:support@techslayers.ca" },
          { "label": "Security", "href": "mailto:security@techslayers.ca" }
        ]
      }
    ]
  },
  "api": {
    "playground": { "display": "interactive", "proxy": true },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Start Here",
        "pages": [
          "index",
          {
            "group": "Platform",
            "pages": ["platform/authentication", "platform/errors", "platform/rate-limits"]
          }
        ]
      },
      {
        "group": "DarkRecon",
        "icon": "radar",
        "pages": [
          "darkrecon/overview",
          "darkrecon/quickstart",
          "darkrecon/authentication",
          {
            "group": "API Reference",
            "pages": [
              "darkrecon/api/start-scan",
              "darkrecon/api/get-scan-results"
            ]
          },
          {
            "group": "Schemas",
            "pages": [
              "darkrecon/schemas/scan-request",
              "darkrecon/schemas/scan-response",
              "darkrecon/schemas/scan-result",
              "darkrecon/schemas/error",
              "darkrecon/schemas/http-validation-error",
              "darkrecon/schemas/validation-error"
            ]
          }
        ]
      },
      {
        "group": "FileScanner",
        "icon": "file-search",
        "pages": [
          "filescanner/overview",
          "filescanner/quickstart",
          "filescanner/authentication",
          { "group": "API Reference", "pages": ["filescanner/api/scan-file"] }
        ]
      },
      {
        "group": "RTSWPScan",
        "icon": "scan-search",
        "pages": [
          "rtswpscan/overview",
          "rtswpscan/quickstart",
          "rtswpscan/authentication",
          {
            "group": "API Reference",
            "pages": ["rtswpscan/api/start-scan-post", "rtswpscan/api/start-scan-get", "rtswpscan/api/get-report"]
          }
        ]
      },
      {
        "group": "RTS Builder",
        "icon": "blocks",
        "pages": [
          "rts-builder/overview",
          "rts-builder/quickstart",
          "rts-builder/authentication",
          {
            "group": "API Reference",
            "pages": [
              "rts-builder/api/list-kits",
              "rts-builder/api/start-run",
              "rts-builder/api/get-status",
              "rts-builder/api/get-results"
            ]
          },
          {
            "group": "Schemas",
            "pages": [
              "rts-builder/schemas/list-kits-response",
              "rts-builder/schemas/start-run-request",
              "rts-builder/schemas/start-run-response-inferred",
              "rts-builder/schemas/run-status-response",
              "rts-builder/schemas/run-results-response",
              "rts-builder/schemas/error-response"
            ]
          }
        ]
      },
      {
        "group": "Senthrex",
        "icon": "siren",
        "pages": [
          "senthrex/overview",
          "senthrex/quickstart",
          "senthrex/authentication",
          {
            "group": "API Reference",
            "pages": [
              "senthrex/api/start-scan-post",
              "senthrex/api/start-scan-get",
              "senthrex/api/get-status",
              "senthrex/api/get-results",
              "senthrex/api/get-scan-json",
              "senthrex/api/download-report",
              "senthrex/api/list-scans",
              "senthrex/api/get-stats",
              "senthrex/api/get-logs",
              "senthrex/api/stop-scan"
            ]
          }
        ]
      },
      {
        "group": "Legba",
        "icon": "shield",
        "pages": [
          "legba/overview",
          "legba/quickstart",
          "legba/authentication",
          "legba/api-keys",
          "legba/instances",
          "legba/images",
          "legba/logs",
          "legba/errors",
          "legba/cookbook"
        ]
      }
    ]
  }
}
